# Dockerfile.vite
# Dedicated Vite development server for local hot module replacement
# Only used in local development via docker-compose.local.yml

FROM node:24-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source files
COPY vite.config.js ./
COPY resources ./resources
COPY public ./public

EXPOSE 5173

# Start Vite dev server bound to all interfaces so Docker can expose it
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
