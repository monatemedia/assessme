# AssessMe — Local Development (Docker Desktop)
# Copy this file to .env for local development

APP_NAME=AssessMe
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# -----------------------------------------------
# DATABASE
# Port 5436 steers clear of 5432 (XAMPP PostgreSQL on Windows host)
# -----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=assessme-db
DB_PORT=5432
DB_DATABASE=assessme_db
DB_USERNAME=assessme_user
DB_PASSWORD=secret

# -----------------------------------------------
# REDIS
# -----------------------------------------------
REDIS_HOST=assessme-redis
REDIS_PORT=6379
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# -----------------------------------------------
# OPENAI
# -----------------------------------------------
OPENAI_API_KEY=CHANGE_ME

# -----------------------------------------------
# MAIL (log locally)
# -----------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@assessme.local
MAIL_FROM_NAME=AssessMe

# -----------------------------------------------
# DOCKER HOST PORTS (local only — not GitHub Secrets)
# -----------------------------------------------
DOCKER_WEB_PORT=8001
DOCKER_POSTGRES_PORT=5436
DOCKER_REDIS_PORT=6390

# -----------------------------------------------
# DEPLOYMENT
# -----------------------------------------------
IMAGE_TAG=dev
