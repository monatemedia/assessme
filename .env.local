# AssessMe — Local Development (Docker Desktop)

APP_NAME=AssessMe
APP_ENV=local
APP_KEY=base64:Gr+/nRsDhXbkLGGt38+N99GSlFegbSeQmefZ9epEEiM=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# SUPERUSER (created automatically on first boot
# if no users exist — safe to run repeatedly)
# -----------------------------------------------
SUPERUSER_NAME=Admin
SUPERUSER_EMAIL=admin@assessme.local
SUPERUSER_PASSWORD=password

# -----------------------------------------------
# DATABASE
# Port 5436 steers clear of 5432 (XAMPP PostgreSQL on Windows host)
# -----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=assessme-db
DB_PORT=5432
DB_DATABASE=assessme_db
DB_USERNAME=assessme_user
DB_PASSWORD=secret

# -----------------------------------------------
# REDIS
# -----------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=assessme-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------
# FILESYSTEM
# -----------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# -----------------------------------------------
# OPENAI
# -----------------------------------------------
OPENAI_API_KEY=CHANGE_ME

# -----------------------------------------------
# MAIL (log locally — no external service needed)
# -----------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@assessme.local
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# VITE
# -----------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------
# DOCKER HOST PORTS (local only — not GitHub Secrets)
# -----------------------------------------------
DOCKER_WEB_PORT=8001
DOCKER_POSTGRES_PORT=5436
DOCKER_REDIS_PORT=6390

# -----------------------------------------------
# DEPLOYMENT
# -----------------------------------------------
IMAGE_TAG=dev
