# AssessMe — Staging Environment
# assessme.monatemedia.com
# Copy this file to .env and fill in the values before deploying

APP_NAME=AssessMe
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://assessme.monatemedia.com

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=assessme-db
DB_PORT=5432
DB_DATABASE=assessme_db
DB_USERNAME=assessme_user
DB_PASSWORD=CHANGE_ME

# -----------------------------------------------
# REDIS
# -----------------------------------------------
REDIS_HOST=assessme-redis
REDIS_PORT=6379
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# -----------------------------------------------
# OPENAI
# -----------------------------------------------
OPENAI_API_KEY=CHANGE_ME

# -----------------------------------------------
# MAIL (log only in staging — no external service)
# -----------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@assessme.monatemedia.com
MAIL_FROM_NAME=AssessMe

# -----------------------------------------------
# NGINX PROXY — auto-routing via VIRTUAL_HOST
# -----------------------------------------------
VIRTUAL_HOST=assessme.monatemedia.com
LETSENCRYPT_HOST=assessme.monatemedia.com

# -----------------------------------------------
# DOCKER HOST PORTS
# Set as GitHub Secrets for portability
# See README.md — Required GitHub Secrets
# -----------------------------------------------
DOCKER_WEB_PORT=8250
DOCKER_POSTGRES_PORT=5475
DOCKER_REDIS_PORT=6400

# -----------------------------------------------
# DEPLOYMENT
# -----------------------------------------------
IMAGE_TAG=staging
